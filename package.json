{
  "name": "@mokatific/meridian",
  "version": "1.2.0",
  "type": "module",
  "description": "Autonomous DLMM LP agent for Meteora on Solana with HiveMind lesson scoring & pruning",
  "main": "index.js",
  "bin": "cli.js",
  "scripts": {
    "setup": "node setup.js",
    "env:encrypt": "node scripts/envrypt.js encrypt",
    "start": "node index.js",
    "start:discord": "yarn workspace @mokatific/meridian-discord-listener run start",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:restart": "pm2 restart meridian --update-env",
    "pm2:logs": "pm2 logs meridian --lines 100",
    "dev": "DRY_RUN=true node index.js",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:syntax": "find . -path ./node_modules -prune -o -name '*.js' -exec node --check {} \\;",
    "test:all": "yarn test:syntax && yarn test",
    "postinstall": "lefthook install && node scripts/patch-anchor.js"
  },
  "knip": {
    "ignore": [
      "discord-listener/**"
    ]
  },
  "workspaces": [
    "discord-listener"
  ],
  "dependencies": {
    "@grammyjs/conversations": "^2.1.1",
    "@grammyjs/menu": "^1.3.1",
    "@grammyjs/router": "^2.0.0",
    "@meteora-ag/dlmm": "1.9.4",
    "@solana/web3.js": "^1.95.0",
    "better-sqlite3": "^12.10.0",
    "bn.js": "^5.2.1",
    "bs58": "^5.0.0",
    "dotenv": "^17.3.1",
    "grammy": "^1.43.0",
    "jsonrepair": "^3.13.3",
    "node-cron": "^3.0.3",
    "openai": "^4.73.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.9",
    "lefthook": "^2.1.8",
    "memfs": "^4.17.0",
    "prettier": "^3.8.3",
    "prettier-plugin-sh": "^0.16.1",
    "vitest": "^2.1.9"
  },
  "prettier": {
    "plugins": [
      "prettier-plugin-sh"
    ],
    "overrides": [
      {
        "files": "*.sh",
        "options": {
          "parser": "sh"
        }
      }
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "yarn@4.15.0"
}
