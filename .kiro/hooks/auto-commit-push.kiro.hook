{
  "name": "Auto Commit & Push",
  "version": "1.0.0",
  "description": "Auto-commit and push after code changes on the main branch. WARNING: This is risky for production - only use for development.",
  "when": {
    "type": "postToolUse",
    "toolTypes": ["write"]
  },
  "then": {
    "type": "runCommand",
    "command": "git add -A && git commit -m \"$(date '+%Y-%m-%d %H:%M') - Code update via Kiro\" && git push origin main"
  }
}
